generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ORGANIZER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum MatchFormat {
  BEST_OF_1
  BEST_OF_3
}

enum MatchStatus {
  SCHEDULED
  CHECK_IN
  VETO
  PROVISIONING
  READY
  LIVE
  COMPLETED
  RELEASING
  RELEASED
  FAILED
  RETRYING
  CANCELLED
}

enum MatchParticipantRole {
  PLAYER
  CAPTAIN
  COACH
}

enum GameServerStatus {
  REQUESTED
  PROVISIONING
  READY
  LIVE
  RELEASING
  RELEASED
  FAILED
}

enum GameServerCommandType {
  PAUSE
  UNPAUSE
  RESTART
  RELEASE
}

enum GameServerCommandStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum TeamMemberRole {
  CAPTAIN
  VICE_CAPTAIN
  PLAYER
  RESERVE
}

enum MarketplaceSellerCategory {
  SPONSOR
  STREAMER
  MERCHANT
  AGENCY
}

enum MarketplaceListingKind {
  SPONSORSHIP
  STREAMER_SERVICE
  PRODUCT
}

enum MarketplaceListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum MarketplaceOrderStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  steamId64   String     @unique @map("steam_id_64") @db.VarChar(17)
  displayName String     @map("display_name") @db.VarChar(100)
  avatarUrl   String?    @map("avatar_url") @db.Text
  profileUrl  String     @map("profile_url") @db.Text
  steamLevel  Int?       @map("steam_level")
  visibilityState Int?   @map("visibility_state")
  profileState Int?      @map("profile_state")
  personaState Int?      @map("persona_state")
  countryCode String?    @map("country_code") @db.VarChar(2)
  stateCode   String?    @map("state_code") @db.VarChar(10)
  steamCreatedAt DateTime? @map("steam_created_at") @db.Timestamptz(3)
  lastLogoffAt DateTime? @map("last_logoff_at") @db.Timestamptz(3)
  role        UserRole   @default(PLAYER)
  status      UserStatus @default(ACTIVE)
  showcaseVisible Boolean @default(true) @map("showcase_visible")
  preferredLocale String? @map("preferred_locale") @db.VarChar(16)
  timeZone     String?    @map("time_zone") @db.VarChar(64)
  currencyCode String?    @map("currency_code") @db.VarChar(3)
  regionCode   String?    @map("region_code") @db.VarChar(32)
  lastLoginAt DateTime   @map("last_login_at") @db.Timestamptz(3)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  captainedTeams Team[] @relation("TeamCaptain")
  teamMemberships TeamMember[]
  teamMessages TeamMessage[]
  sentDirectMessages DirectMessage[] @relation("DirectMessageSender")
  receivedDirectMessages DirectMessage[] @relation("DirectMessageRecipient")
  marketplaceSeller MarketplaceSeller?
  marketplaceOrders MarketplaceOrder[] @relation("MarketplaceBuyer")
  requestedServerCommands GameServerCommand[]

  @@map("users")
}

model Session {
  sid    String   @id @db.VarChar
  sess   Json
  expire DateTime @db.Timestamptz(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model RateLimit {
  key       String   @id @db.VarChar(255)
  count     Int
  resetAt   DateTime @map("reset_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([resetAt])
  @@map("rate_limits")
}

model AppState {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("app_state")
}

model GameMatch {
  id            String             @id @default(uuid()) @db.Uuid
  tournamentRef String?            @map("tournament_ref") @db.VarChar(100)
  createdById   String             @map("created_by_id") @db.Uuid
  format        MatchFormat
  status        MatchStatus        @default(SCHEDULED)
  regionCode    String?            @map("region_code") @db.VarChar(32)
  scheduledAt   DateTime           @map("scheduled_at") @db.Timestamptz(3)
  version       Int                @default(0)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  participants  MatchParticipant[]
  latencies     MatchLatency[]
  allocations   GameServerAllocation[]

  @@index([status, scheduledAt])
  @@index([createdById])
  @@map("matches")
}

model MatchParticipant {
  id          String               @id @default(uuid()) @db.Uuid
  matchId     String               @map("match_id") @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  teamRef     String               @map("team_ref") @db.VarChar(100)
  role        MatchParticipantRole @default(PLAYER)
  checkedInAt DateTime?            @map("checked_in_at") @db.Timestamptz(3)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  match       GameMatch            @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
  @@map("match_participants")
}

model MatchLatency {
  id         String    @id @default(uuid()) @db.Uuid
  matchId    String    @map("match_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  regionCode String    @map("region_code") @db.VarChar(32)
  latencyMs  Int       @map("latency_ms")
  measuredAt DateTime  @map("measured_at") @db.Timestamptz(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  match      GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId, regionCode])
  @@index([matchId, regionCode])
  @@map("match_latencies")
}

model GameServerAllocation {
  id               String           @id @default(uuid()) @db.Uuid
  matchId          String           @map("match_id") @db.Uuid
  provider         String           @db.VarChar(50)
  providerServerId String?          @map("provider_server_id") @db.VarChar(255)
  regionCode       String           @map("region_code") @db.VarChar(32)
  status           GameServerStatus @default(REQUESTED)
  secretRef        String?          @map("secret_ref") @db.VarChar(255)
  publicHost       String?          @map("public_host") @db.VarChar(255)
  gamePort         Int?             @map("game_port")
  rconPort         Int?             @map("rcon_port")
  encryptedPassword String?         @map("encrypted_password") @db.Text
  encryptedRconPassword String?     @map("encrypted_rcon_password") @db.Text
  lastHeartbeatAt  DateTime?        @map("last_heartbeat_at") @db.Timestamptz(3)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  releasedAt       DateTime?        @map("released_at") @db.Timestamptz(3)
  match            GameMatch        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  commands         GameServerCommand[]

  @@index([status, createdAt])
  @@index([matchId])
  @@map("game_server_allocations")
}

model GameServerCommand {
  id             String                  @id @default(uuid()) @db.Uuid
  allocationId   String                  @map("allocation_id") @db.Uuid
  requestedById  String                  @map("requested_by_id") @db.Uuid
  type           GameServerCommandType
  status         GameServerCommandStatus @default(PENDING)
  idempotencyKey String                  @unique @map("idempotency_key") @db.VarChar(180)
  errorCode      String?                 @map("error_code") @db.VarChar(100)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  processedAt    DateTime?               @map("processed_at") @db.Timestamptz(3)
  allocation     GameServerAllocation    @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  requestedBy    User                    @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([allocationId, createdAt])
  @@map("game_server_commands")
}

model OutboxEvent {
  id             String    @id @default(uuid()) @db.Uuid
  aggregateType  String    @map("aggregate_type") @db.VarChar(80)
  aggregateId    String    @map("aggregate_id") @db.VarChar(100)
  eventType      String    @map("event_type") @db.VarChar(120)
  idempotencyKey String    @unique @map("idempotency_key") @db.VarChar(180)
  payload        Json
  occurredAt     DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(3)
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(3)
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz(3)
  lockedBy       String?   @map("locked_by") @db.VarChar(100)
  attempts       Int       @default(0)
  lastError      String?   @map("last_error") @db.Text

  @@index([publishedAt, lockedUntil, occurredAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model AuditEntry {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String   @db.VarChar(120)
  resourceType String   @map("resource_type") @db.VarChar(80)
  resourceId   String   @map("resource_id") @db.VarChar(100)
  metadata     Json
  occurredAt   DateTime @default(now()) @map("occurred_at") @db.Timestamptz(3)

  @@index([resourceType, resourceId, occurredAt])
  @@index([actorId, occurredAt])
  @@map("audit_entries")
}

model Team {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(100)
  slug          String        @unique @db.VarChar(120)
  tag           String        @db.VarChar(12)
  description   String?       @db.Text
  region        String        @db.VarChar(80)
  captainUserId String        @map("captain_user_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  captain       User          @relation("TeamCaptain", fields: [captainUserId], references: [id], onDelete: Restrict)
  members       TeamMember[]
  messages      TeamMessage[]

  @@index([captainUserId])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(uuid()) @db.Uuid
  teamId    String         @map("team_id") @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  role      TeamMemberRole @default(PLAYER)
  joinedAt  DateTime       @default(now()) @map("joined_at") @db.Timestamptz(3)
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamMessage {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @map("team_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([teamId, createdAt])
  @@map("team_messages")
}

model DirectMessage {
  id          String   @id @default(uuid()) @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  recipientId String   @map("recipient_id") @db.Uuid
  body        String   @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  sender      User     @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  recipient   User     @relation("DirectMessageRecipient", fields: [recipientId], references: [id], onDelete: Restrict)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
  @@map("direct_messages")
}

model MarketplaceSeller {
  id          String                    @id @default(uuid()) @db.Uuid
  userId      String                    @unique @map("user_id") @db.Uuid
  storeName   String                    @map("store_name") @db.VarChar(100)
  slug        String                    @unique @db.VarChar(120)
  category    MarketplaceSellerCategory
  description String                    @db.Text
  websiteUrl  String?                   @map("website_url") @db.Text
  currencyCode String                   @default("BRL") @map("currency_code") @db.VarChar(3)
  verified    Boolean                   @default(false)
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  user        User                      @relation(fields: [userId], references: [id], onDelete: Restrict)
  listings    MarketplaceListing[]
  orders      MarketplaceOrder[]

  @@map("marketplace_sellers")
}

model MarketplaceListing {
  id            String                   @id @default(uuid()) @db.Uuid
  sellerId      String                   @map("seller_id") @db.Uuid
  kind          MarketplaceListingKind
  status        MarketplaceListingStatus @default(DRAFT)
  title         String                   @db.VarChar(140)
  description   String                   @db.Text
  game          String                   @db.VarChar(60)
  audience      String?                  @db.VarChar(80)
  priceCents    Int                      @map("price_cents")
  currencyCode  String                   @default("BRL") @map("currency_code") @db.VarChar(3)
  stockQuantity Int                      @default(0) @map("stock_quantity")
  imageUrl      String?                  @map("image_url") @db.Text
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  seller        MarketplaceSeller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders        MarketplaceOrder[]

  @@index([status, kind, createdAt])
  @@index([sellerId, status])
  @@map("marketplace_listings")
}

model MarketplaceOrder {
  id          String                 @id @default(uuid()) @db.Uuid
  listingId   String                 @map("listing_id") @db.Uuid
  sellerId    String                 @map("seller_id") @db.Uuid
  buyerUserId String                 @map("buyer_user_id") @db.Uuid
  quantity    Int                    @default(1)
  totalCents  Int                    @map("total_cents")
  currencyCode String                @default("BRL") @map("currency_code") @db.VarChar(3)
  status      MarketplaceOrderStatus @default(PENDING)
  brief       String                 @db.VarChar(500)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  listing     MarketplaceListing     @relation(fields: [listingId], references: [id], onDelete: Restrict)
  seller      MarketplaceSeller      @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  buyer       User                   @relation("MarketplaceBuyer", fields: [buyerUserId], references: [id], onDelete: Restrict)

  @@index([sellerId, status, createdAt])
  @@index([buyerUserId, createdAt])
  @@map("marketplace_orders")
}
