NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://clutchzone:local_development_only@localhost:5433/clutchzone?schema=public
SESSION_SECRET=generate_at_least_32_random_characters
STEAM_API_KEY=your_steam_web_api_key
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
# Chave AES-256 (64 caracteres hexadecimais) compartilhada pelo backend e worker CS2.
# CS2_SECRET_KEY=
EVENT_BROKER_URL=amqp://broker-user:broker-password@localhost:5672
OUTBOX_EXCHANGE=clutchzone.events
EVENT_MATCH_QUEUE=clutchzone.match-orchestrator
OUTBOX_WORKER_ID=local-outbox-1
OUTBOX_BATCH_SIZE=50
OUTBOX_LEASE_MS=30000
OUTBOX_POLL_MS=1000

# Somente no host Linux que executa Docker e o worker CS2:
# CS2_GSLT=
# CS2_PUBLIC_HOST=cs2.example.com
# CS2_SERVER_IMAGE=clutchzone/cs2-server:local
# CS2_SECRET_DIR=/var/lib/clutchzone/cs2-secrets
# CS2_GAME_PORT=27015
# CS2_RCON_PORT=27015
# CS2_WORKER_POLL_MS=2000
